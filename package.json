{
  "name": "action-openapi-sync",
  "version": "0.1.0",
  "description": "GitHub Action that synchronizes OpenAPI schema files between repositories",
  "author": "FingerprintJS, Inc (https://fingerprint.com)",
  "license": "MIT",
  "scripts": {
    "prepare": "husky",
    "build": "node esbuild.config.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:dts": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --check .",
    "format:fix": "prettier --write ."
  },
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.30.1",
  "devDependencies": {
    "@commitlint/cli": "^20.4.3",
    "@fingerprintjs/commit-lint-dx-team": "^0.1.0",
    "@fingerprintjs/eslint-config-dx-team": "^0.2.0",
    "@fingerprintjs/prettier-config-dx-team": "^0.3.0",
    "@fingerprintjs/tsconfig-dx-team": "^0.0.2",
    "@types/node": "^25.3.5",
    "@vitest/coverage-v8": "^4.0.18",
    "esbuild": "^0.27.3",
    "eslint": "^8.56.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
